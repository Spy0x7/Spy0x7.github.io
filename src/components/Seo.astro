---
import { SEO } from 'astro-seo';

interface Props {
    title?: string;
    description?: string;
    ogImage?: string;
}
const {
    title,
    description = 'I post My Hackthebox writeups and other InfoSec findings here.',
    ogImage = 'https://spy0x7.vercel.app/og.png',
} = Astro.props as Props;
const twitterHandle = '@spy0x7';
---

<SEO
    title={title ? `${title} | spy0x7` : 'Spy0x7 Blogs'}
    description={description}
    openGraph={{
        basic: {
            title: title ? `${title} | spy0x7` : 'Spy0x7 Blogs',
            type: 'website',
            image: ogImage,
        },
        optional: {
            description,
        },
    }}
    twitter={{
        creator: twitterHandle,
        card: 'summary_large_image',
        site: twitterHandle,
        title: 'spy0x7',
        description,
        image: ogImage,
        imageAlt: 'spy0x7',
    }}
    extend={{
        link: [
            {
                rel: 'sitemap',
                href: '/sitemap-index.xml',
            },
        ],
        meta: [
            {
                name: 'google-site-verification',
                content: '6zkv0IdPP57AIvam4aXqSqjJ5Ba4U1DpU5Kvyg2fxuo',
            },
            {
                name: 'yandex-verification',
                content: 'd1860867354dc963',
            },
        ],
    }}
/>
