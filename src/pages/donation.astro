---
import BuyMeACoffeeSvg from '../components/BuyMeACoffeeSvg.astro';
import SupportersData from '../components/SupportersData.astro';
import MainLayout from '../layouts/MainLayout.astro';

type SupporterData = {
    support_id: number;
    support_note: string | null;
    support_coffees: number;
    support_created_on: Date;
    supporter_name: string;
};

type Supporter = {
    current_page: number;
    data: {
        support_id: number;
        support_note: string | null;
        support_coffees: number;
        support_created_on: Date;
        supporter_name: string;
    }[];
};

let page = 1;
let allSupporters: SupporterData[] = [];

while (true) {
    const response = await fetch(
        `https://developers.buymeacoffee.com/api/v1/supporters?page=${page}`,
        {
            headers: {
                Authorization: `Bearer ${import.meta.env.DONATION_API_SECRET}`,
            },
        }
    );

    if (!response.ok) {
        console.error('❌ Failed to fetch supporters:', await response.text());
        break;
    }

    let supporters: Supporter | null = null;

    try {
        supporters = await response.json();
    } catch (err) {
        console.error('❌ Failed to parse JSON:', err);
        break;
    }

    if (!supporters?.data || supporters.data.length === 0) {
        break;
    }

    allSupporters = allSupporters.concat(supporters.data);
    page++;
}

---

<MainLayout
    title='Donation'
    description='Donation page where every person who donates some dollars is listed here.'
>
    <div
        class='flex flex-col justify-center items-start max-w-2xl mx-auto mb-16'
    >
        <h1
            class='font-bold text-3xl md:text-5xl tracking-tight mb-4 text-black dark:text-white'
            transition:name='heading'
        >
            Donation
        </h1>
        <div class='mb-8'>
            <p class='text-gray-600 dark:text-gray-400 mb-4'>
                Hey 👋 I Please Support Me To Get OSWE Please./
            </p>
            <BuyMeACoffeeSvg />
        </div>
        <h6
            class='font-bold text-2xl md:text-3xl tracking-tight mb-4 text-black dark:text-white'
        >
            Recent Supporters
        </h6>
        <div class='mt-4 space-y-8'>
            {
                allSupporters.map((supporter) => (
                    <SupportersData
                        key={supporter.support_id}
                        msg={supporter.support_note}
                        name={supporter.supporter_name}
                        coffee={supporter.support_coffees}
                        date={supporter.support_created_on}
                    />
                ))
            }
        </div>
    </div>
</MainLayout>
