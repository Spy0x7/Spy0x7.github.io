            "destination": "/blog/hackthebox-cache-writeup",
            "statusCode": 301
        },
        {
            "source": "/blog/HackTheBox%E2%80%94Omni%E2%80%94Writeup",
            "destination": "/blog/hackthebox-omni-writeup",
            "statusCode": 301
        },
        {
            "source": "/blog/Hackthebox%E2%80%94Seal%E2%80%94Writeup",
            "destination": "/blog/hackthebox-seal-writeup",
            "statusCode": 301
        },
        {
            "source": "/blog/Easylfi",
            "destination": "/blog/easylfi",
            "statusCode": 301
        },
        {
            "source": "/blog/Proving-Grounds-ClamAV",
            "destination": "/blog/proving-grounds-clamav",
            "statusCode": 301
        },
        {
            "source": "/blog/Groovy-Script%E2%80%94Remote-Code-Execution",
            "destination": "/blog/groovy-script-remote-code-execution",
            "statusCode": 301
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "default-src 'self';script-src 'self' 'unsafe-eval' 'unsafe-inline' giscus.app www.googletagmanager.com cdn.vercel-insights.com va.vercel-scripts.com;child-src giscus.app;style-src 'self' 'unsafe-inline';img-src * blob: data:;media-src 'self';connect-src *;font-src 'self';"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "origin-when-cross-origin"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "ALLOW-FROM=giscus.app"
                },
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-DNS-Prefetch-Control",
                    "value": "on"
                },
                {
                    "key": "Strict-Transport-Security",
                    "value": "max-age=31536000; includeSubDomains; preload"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                },
                {
                    "key": "Permissions-Policy",
                    "value": "camera=(), microphone=(), geolocation=()"
                }
            ]
        }
    ]
}
